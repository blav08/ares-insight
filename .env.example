# Sablona konfigurace. Zkopiruj do .env a vypln skutecnymi hodnotami.
# .env je v .gitignore (klice se nikdy necommituji), tahle sablona ma byt PRAZDNA.

# --- Neo4j ---
# Lokalni vyvoj (docker compose): bolt://localhost:7687 + heslo z compose.
# AuraDB Free (Faze 4): vloz URI + heslo z credentials souboru, ktery Aura vygeneruje.
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=local-dev-password

# --- Anthropic ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# --- Langfuse ---
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
